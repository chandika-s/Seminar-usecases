# Copy to .env and fill in; do not commit .env
# Required: Bedrock AgentCore runtime ARN (e.g. from Lab 5 deployment)
AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:agent-runtime/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# AWS region for bedrock-agentcore
AWS_REGION=us-east-1

# Optional: runtime qualifier
# AGENT_QUALIFIER=DEFAULT

# Optional: if set, webhook requests must include this value in
# X-Webhook-Secret header or Authorization: Bearer <value>
# WEBHOOK_SECRET=your-shared-secret

# Optional: server port (default 8080)
# PORT=8080
