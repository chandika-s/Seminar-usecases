# Required for OpenAI. Do not commit.
# OPENAI_API_KEY=sk-...
# Optional: model (default gpt-4o-mini)
# OPENAI_MODEL_ID=gpt-4o

# Optional. Default kubeconfig is ~/.kube/config (Docker Desktop).
# KUBECONFIG=/path/to/kubeconfig

# Optional. Max memory (MB) the agent may set when auto-fixing OOM (default 2048).
# K8S_MAX_MEMORY_LIMIT_MB=2048

# Optional. For escalation when agent cannot auto-fix (JIRA Cloud).
# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_PROJECT_KEY=PROJ
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your-api-token

# Optional. For Slack notification on escalation.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
